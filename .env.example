# =============================================================================
#  .env.example — copia a .env y rellena. .env está gitignored (nunca se commitea).
#  Convención del starter: cuando una feature necesite una credencial nueva, se
#  añade aquí como placeholder REEMPLAZA_... con una guía corta inline arriba.
#  Para deploy, estas vars también van en tu plataforma de hosting (runtime).
# =============================================================================

# --- MCP: GitHub ---
# Sólo si usas el MCP de GitHub o que los agentes operen con `gh`.
# Cómo obtenerlo: github.com → Settings → Developer settings → Personal access
# tokens → Fine-grained → da permisos de repo (contents, issues, pull requests).
GITHUB_TOKEN=REEMPLAZA_github_pat

# --- Deploy: plataforma de hosting (ejemplo Coolify) ---
# Usados por el subagente deploy-ops / skill agentic-microservice-deployer.
# Cómo obtenerlos: panel de Coolify → Keys & Tokens → API tokens (token);
# el UUID de la app está en la URL de su página dentro del panel.
COOLIFY_API_URL=REEMPLAZA_https://tu-coolify.tu-dominio.com
COOLIFY_API_TOKEN=REEMPLAZA_coolify_api_token
COOLIFY_APP_UUID=REEMPLAZA_uuid_de_la_app

# --- App: secretos del proyecto (se añaden por feature) ---
# Ejemplos típicos que tu app irá necesitando (descomenta/añade según tu stack):
# Clave de cifrado en reposo de secretos (AES-256-GCM = 32 bytes en hex/base64).
# Generar: `openssl rand -hex 32`. NO la rotes a la ligera si ya cifró datos.
# ENCRYPTION_KEY=REEMPLAZA_32_bytes_hex
# Base de datos
# DATABASE_URL=REEMPLAZA_postgres://user:pass@host:5432/db
# Almacenamiento de objetos S3-compatible (R2/MinIO)
# S3_ENDPOINT=REEMPLAZA
# S3_ACCESS_KEY_ID=REEMPLAZA
# S3_SECRET_ACCESS_KEY=REEMPLAZA
# Secreto para proteger endpoints de cron
# CRON_SECRET=REEMPLAZA
